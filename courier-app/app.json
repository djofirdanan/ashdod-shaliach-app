{
  "expo": {
    "name": "אשדוד-שליח שליח",
    "slug": "ashdod-shaliach-courier",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#1A1B2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ashdodshaliach.courier"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1B2E"
      },
      "package": "com.ashdodshaliach.courier",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "VIBRATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-notifications",
      "expo-location",
      "expo-camera"
    ],
    "extra": {
      "eas": {
        "projectId": "ashdod-shaliach-courier"
      }
    }
  }
}
